{
  "name": "noteeees",
  "displayName": "Noteeees",
  "description": "Simple markdown notes extension",
  "version": "0.0.44",
  "publisher": "HidenobuNagai",
  "icon": "assets/icon.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/hidenobunagai/noteeees.git"
  },
  "engines": {
    "vscode": "^1.104.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [],
  "main": "./dist/extension.js",
  "contributes": {
    "walkthroughs": [
      {
        "id": "noteeees.welcome",
        "title": "Welcome to Noteeees",
        "description": "Get started with your markdown notes extension.",
        "steps": [
          {
            "id": "setupDirectory",
            "title": "Set up your notes directory",
            "description": "Choose where your notes will be stored on this machine.\n[Run Setup](command:notes.runSetup)",
            "media": {
              "markdown": "assets/walkthrough-setup.md"
            }
          },
          {
            "id": "firstNote",
            "title": "Create your first note",
            "description": "Press the shortcut (`Cmd+Shift+N` on Mac, `Ctrl+Shift+N` on Windows/Linux) or click the button to create a new markdown note.\n[Create Note](command:notes.newNote)",
            "media": {
              "markdown": "assets/walkthrough-note.md"
            }
          },
          {
            "id": "moments",
            "title": "Capture a Moment",
            "description": "Open the Moments panel from the Activity Bar (the lightning icon) to quickly capture thoughts and tasks.\n[Open Moments](command:notesMomentsView.focus)",
            "media": {
              "markdown": "assets/walkthrough-moments.md"
            }
          }
        ]
      }
    ],
    "snippets": [
      {
        "language": "markdown",
        "path": "./snippets/markdown.json"
      }
    ],
    "commands": [
      {
        "command": "notes.runSetup",
        "title": "Noteeees: Run Setup"
      },
      {
        "command": "notes.refreshSidebar",
        "title": "Noteeees: Refresh Sidebar",
        "icon": "$(refresh)"
      },
      {
        "command": "notes.newNote",
        "title": "Noteeees Note: New"
      },
      {
        "command": "notes.listNotes",
        "title": "Noteeees Note: Search"
      },
      {
        "command": "notes.focusMoments",
        "title": "Noteeees: Open Moments"
      },
      {
        "command": "notes.showOpenTasksOverview",
        "title": "Noteeees Moments: Show Open Tasks Overview"
      },
      {
        "command": "notes.searchTags",
        "title": "Noteeees Sidebar: Search Tags",
        "icon": "$(tag)"
      },
      {
        "command": "notes.toggleTagSort",
        "title": "Noteeees Sidebar: Toggle Tag Sort",
        "icon": "$(arrow-swap)"
      },
      {
        "command": "notes.pinNote",
        "title": "Pin Note",
        "icon": "$(pin)"
      },
      {
        "command": "notes.unpinNote",
        "title": "Unpin Note",
        "icon": "$(pinned)"
      },
      {
        "command": "notes.movePinnedNoteUp",
        "title": "Move Pinned Note Up",
        "icon": "$(arrow-up)"
      },
      {
        "command": "notes.movePinnedNoteDown",
        "title": "Move Pinned Note Down",
        "icon": "$(arrow-down)"
      }
    ],
    "keybindings": [
      {
        "command": "notes.newNote",
        "key": "ctrl+shift+n",
        "mac": "cmd+shift+n"
      },
      {
        "command": "notes.focusMoments",
        "key": "ctrl+shift+m",
        "mac": "cmd+shift+m"
      },
      {
        "command": "notes.movePinnedNoteUp",
        "key": "ctrl+alt+up",
        "mac": "cmd+alt+up",
        "when": "view == notesExplorer && viewItem == pinnedNoteFile"
      },
      {
        "command": "notes.movePinnedNoteDown",
        "key": "ctrl+alt+down",
        "mac": "cmd+alt+down",
        "when": "view == notesExplorer && viewItem == pinnedNoteFile"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "notesMoments",
          "title": "Moments",
          "icon": "assets/moments-icon.svg"
        }
      ]
    },
    "views": {
      "explorer": [
        {
          "id": "notesExplorer",
          "name": "Noteeees",
          "icon": "$(notebook)",
          "contextualTitle": "Memory Notes"
        }
      ],
      "notesMoments": [
        {
          "type": "webview",
          "id": "notesMomentsView",
          "name": "Moments"
        }
      ]
    },
    "menus": {
      "view/title": [
        {
          "command": "notes.listNotes",
          "when": "view == notesExplorer",
          "group": "navigation@1"
        },
        {
          "command": "notes.searchTags",
          "when": "view == notesExplorer",
          "group": "navigation@2"
        },
        {
          "command": "notes.toggleTagSort",
          "when": "view == notesExplorer",
          "group": "navigation@3"
        },
        {
          "command": "notes.refreshSidebar",
          "when": "view == notesExplorer",
          "group": "navigation@4"
        }
      ],
      "view/item/context": [
        {
          "command": "notes.pinNote",
          "when": "view == notesExplorer && viewItem == noteFile",
          "group": "inline"
        },
        {
          "command": "notes.unpinNote",
          "when": "view == notesExplorer && viewItem == pinnedNoteFile",
          "group": "inline"
        },
        {
          "command": "notes.movePinnedNoteUp",
          "when": "view == notesExplorer && viewItem == pinnedNoteFile",
          "group": "navigation@1"
        },
        {
          "command": "notes.movePinnedNoteDown",
          "when": "view == notesExplorer && viewItem == pinnedNoteFile",
          "group": "navigation@2"
        }
      ]
    },
    "configuration": {
      "title": "Noteeees",
      "properties": {
        "notes.notesDirectory": {
          "type": "string",
          "default": "",
          "scope": "machine",
          "description": "Legacy fallback setting for importing older Notes directory values. Run Setup now stores the selected folder locally per machine in extension storage."
        },
        "notes.dateFormat": {
          "type": "string",
          "default": "YYYY-MM-DD HH:mm",
          "enum": [
            "YYYY-MM-DD HH:mm",
            "YYYY-MM-DD",
            "MM/DD/YYYY HH:mm",
            "DD.MM.YYYY HH:mm"
          ],
          "description": "Date format for new entries."
        },
        "notes.defaultNoteTitle": {
          "type": "string",
          "default": "{dt}_{title}.{ext}",
          "description": "Filename format for new notes. Tokens: {dt} = datetime, {title} = input title, {ext} = file extension."
        },
        "notes.noteTitleConvertSpaces": {
          "type": "string",
          "default": "_",
          "description": "Character to replace spaces in note titles. Set to empty string to keep spaces."
        },
        "notes.defaultSnippet": {
          "type": "object",
          "default": {
            "langId": "markdown",
            "name": "noteeees_template_note"
          },
          "properties": {
            "langId": {
              "type": "string",
              "description": "Language ID for the snippet."
            },
            "name": {
              "type": "string",
              "description": "Snippet name to insert. Set to null to disable."
            }
          },
          "description": "Default VS Code snippet to insert after creating a note."
        },
        "notes.templates": {
          "type": "array",
          "default": [],
          "items": {
            "type": "string"
          },
          "description": "List of custom template names. Each name maps to a VS Code snippet named noteeees_template_{name}."
        },
        "notes.sidebarRecentLimit": {
          "type": "number",
          "default": 20,
          "minimum": 0,
          "description": "Number of notes shown in the Recent section of the sidebar. Set to 0 to show all notes."
        },
        "notes.sidebarTagSort": {
          "type": "string",
          "default": "frequency",
          "enum": [
            "frequency",
            "alphabetical"
          ],
          "description": "Sort mode for the Tags section in the sidebar."
        },
        "notes.momentsSubfolder": {
          "type": "string",
          "default": "moments",
          "scope": "machine",
          "description": "Subfolder within the notes directory where Moments entries are stored. Each day creates a YYYY-MM-DD.md file."
        },
        "notes.momentsSendOnEnter": {
          "type": "boolean",
          "default": true,
          "description": "If true, pressing Enter sends the Moment entry. Use Shift+Enter for a newline. If false, use Ctrl+Enter / Cmd+Enter to send."
        },
        "notes.momentsFeedDays": {
          "type": "number",
          "default": 7,
          "minimum": 1,
          "maximum": 30,
          "description": "Number of days shown in the continuous Moments feed, counting backward from today."
        },
        "notes.momentsInboxFilter": {
          "type": "string",
          "default": "all",
          "enum": [
            "all",
            "open",
            "done"
          ],
          "description": "Default filter for the Moments Inbox overview. The last selected value is saved here and reused the next time Inbox opens."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run package",
    "compile": "npm run check-types && npm run lint && node esbuild.js && bun run compile:mcp",
    "watch": "npm-run-all -p watch:*",
    "watch:esbuild": "node esbuild.js --watch",
    "watch:tsc": "tsc --noEmit --watch --project tsconfig.json",
    "package": "npm run check-types && npm run lint && node esbuild.js --production && bun run compile:mcp",
    "compile-tests": "tsc -p . --outDir out",
    "watch-tests": "tsc -p . -w --outDir out",
    "pretest": "npm run compile-tests && npm run compile && npm run lint && bun run test:mcp",
    "check-types": "tsc --noEmit",
    "lint": "eslint src",
    "compile:mcp": "cd notes-mcp && bun run build",
    "test:mcp": "cd notes-mcp && bun test",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/vscode": "^1.104.0",
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "typescript-eslint": "^8.52.0",
    "eslint": "^9.39.2",
    "esbuild": "^0.27.2",
    "npm-run-all": "^4.1.5",
    "typescript": "^5.9.3",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2"
  },
  "dependencies": {
    "@vscode/webview-ui-toolkit": "^1.4.0"
  }
}
